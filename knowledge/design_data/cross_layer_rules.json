{
  "schemaVersion": "1.0",
  "rules": [
    {
      "id": "platform_pc_console_vs_mobile_input",
      "severity": "CRITICAL",
      "if": {
        "profile.primaryPlatform": [
          "pc_console"
        ]
      },
      "forbidsOptionId": [
        "mobile_touch",
        "touch_only",
        "phone_touch_primary"
      ],
      "reason": "PC / 主机为主的项目不应把手机触屏作为目标玩家的主要设备场景。"
    },
    {
      "id": "buyout_vs_low_payment_intent",
      "severity": "CRITICAL",
      "if": {
        "profile.businessModel": [
          "buyout",
          "premium_with_dlc"
        ]
      },
      "forbidsOptionId": [
        "non_payer",
        "high_frequency_iap",
        "gacha_primary"
      ],
      "reason": "买断制项目需要玩家有明确购买意愿,不应把目标玩家标为倾向不付费。"
    },
    {
      "id": "rated_m_vs_low_age_band",
      "severity": "CRITICAL",
      "if": {
        "profile.contentRating": [
          "mature_17_plus"
        ]
      },
      "forbidsOptionId": [
        "age_0_6",
        "age_7_12"
      ],
      "reason": "M / 17+ 内容分级不应匹配低龄儿童目标年龄段。"
    },
    {
      "id": "long_session_vs_short_session_option",
      "severity": "CRITICAL",
      "if": {
        "profile.targetSessionBand": [
          "session_20_40",
          "session_40_plus"
        ]
      },
      "forbidsOptionId": [
        "session_1_3",
        "session_3_10",
        "session_1_3_min",
        "session_1_5_min"
      ],
      "reason": "20 分钟以上目标会话不应同时选择 1-3 分钟或极短会话作为目标玩家单次时长。"
    },
    {
      "id": "indie_vs_large_team_scope",
      "severity": "WARNING",
      "if": {
        "profile.targetScale": [
          "indie"
        ]
      },
      "forbidsOptionId": [
        "large_team",
        "large_team_pipeline",
        "department_scale_content"
      ],
      "reason": "独立游戏规模不应依赖大型团队生产结构作为核心范围假设。"
    },
    {
      "id": "global_release_vs_single_language_lock",
      "severity": "WARNING",
      "if": {
        "profile.regionScope": [
          "global"
        ]
      },
      "forbidsOptionId": [
        "single_language",
        "single_locale_only",
        "local_only_copy"
      ],
      "reason": "全球发行不应把单语种或单区域文案锁定作为发布前提。"
    }
  ]
}
