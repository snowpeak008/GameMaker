{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "loop_card_v1",
  "kind": "loop",
  "schemaVersion": "v1",
  "title": "Loop Card v1",
  "type": "object",
  "required": [
    "kind",
    "id",
    "nodes",
    "exitConditions"
  ],
  "properties": {
    "kind": {
      "const": "loop"
    },
    "schemaVersion": {
      "const": "v1"
    },
    "schema": {
      "const": "loop_card_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "action"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "exitConditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
