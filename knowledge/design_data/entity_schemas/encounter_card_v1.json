{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "encounter_card_v1",
  "kind": "encounter",
  "schemaVersion": "v1",
  "title": "Encounter Card v1",
  "type": "object",
  "required": [
    "kind",
    "id",
    "phases",
    "winCondition"
  ],
  "properties": {
    "kind": {
      "const": "encounter"
    },
    "schemaVersion": {
      "const": "v1"
    },
    "schema": {
      "const": "encounter_card_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "objective"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "winCondition": {
      "type": "string",
      "minLength": 1
    }
  }
}
