{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "operation_card_v1",
  "kind": "operation",
  "schemaVersion": "v1",
  "title": "Operation Card v1",
  "type": "object",
  "required": [
    "kind",
    "id",
    "device",
    "mapping"
  ],
  "properties": {
    "kind": {
      "const": "operation"
    },
    "schemaVersion": {
      "const": "v1"
    },
    "schema": {
      "const": "operation_card_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "device": {
      "type": "string",
      "minLength": 1
    },
    "mapping": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "intent",
          "binding"
        ],
        "properties": {
          "intent": {
            "type": "string",
            "minLength": 1
          },
          "binding": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
