{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "numeric_curve_v1",
  "kind": "numeric_curve",
  "schemaVersion": "v1",
  "title": "Numeric Curve v1",
  "type": "object",
  "required": [
    "kind",
    "id",
    "boundaryRule"
  ],
  "anyOf": [
    {
      "required": [
        "formula"
      ]
    },
    {
      "required": [
        "sampleCurve"
      ]
    }
  ],
  "properties": {
    "kind": {
      "const": "numeric_curve"
    },
    "schemaVersion": {
      "const": "v1"
    },
    "schema": {
      "const": "numeric_curve_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "formula": {
      "type": "string",
      "minLength": 1
    },
    "sampleCurve": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "x",
          "y"
        ],
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        }
      }
    },
    "boundaryRule": {
      "type": "object"
    }
  }
}
