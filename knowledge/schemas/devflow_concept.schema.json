{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DevFlow Concept Package Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "project_id",
    "package_id",
    "package_type",
    "source_id",
    "stage",
    "version",
    "design_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "package_id": {
      "type": "string"
    },
    "package_type": {
      "type": "string",
      "const": "Concept"
    },
    "package_type_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string",
      "const": "Concept"
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stage": {
      "type": "integer",
      "const": 0
    },
    "stage_slug": {
      "type": "string"
    },
    "stage_title": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_by": {
      "type": "string"
    },
    "design_summary": {
      "type": "object",
      "required": [
        "domain_count",
        "node_count",
        "checklist_count",
        "option_group_count",
        "validation_errors",
        "validation_warnings"
      ],
      "properties": {
        "domain_count": {
          "type": "integer",
          "minimum": 0
        },
        "domain_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "checklist_count": {
          "type": "integer",
          "minimum": 0
        },
        "option_group_count": {
          "type": "integer",
          "minimum": 0
        },
        "validation_errors": {
          "type": "integer",
          "minimum": 0
        },
        "validation_warnings": {
          "type": "integer",
          "minimum": 0
        },
        "data_source": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
