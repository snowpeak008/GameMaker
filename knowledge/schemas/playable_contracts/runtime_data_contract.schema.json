{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime_data_contract.schema.json",
  "title": "Runtime Data Contract",
  "type": "object",
  "required": ["schema_version", "tables"],
  "properties": {
    "schema_version": {"type": "string"},
    "tables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["table_id", "purpose", "consumer_systems", "records"],
        "properties": {
          "table_id": {"type": "string", "minLength": 1},
          "purpose": {"type": "string"},
          "consumer_systems": {"type": "array"},
          "records": {"type": "array", "minItems": 1}
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id", "entity_type", "fields"],
        "properties": {
          "entity_id": {"type": "string", "minLength": 1},
          "entity_type": {"type": "string"},
          "source_table": {"type": "string"},
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["field", "type"],
              "properties": {
                "field": {"type": "string"},
                "type": {"type": "string"},
                "required": {"type": "boolean"},
                "default": {}
              }
            }
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relation_id", "from", "to", "relation_type"],
        "properties": {
          "relation_id": {"type": "string"},
          "from": {"type": "string"},
          "to": {"type": "string"},
          "relation_type": {"type": "string"}
        }
      }
    },
    "state_models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model_id", "owner_system", "fields", "initial_values"],
        "properties": {
          "model_id": {"type": "string"},
          "owner_system": {"type": "string"},
          "fields": {"type": "array"},
          "initial_values": {"type": "object"}
        }
      }
    },
    "consumer_systems": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "contract_refs": {"type": "object"}
  }
}
