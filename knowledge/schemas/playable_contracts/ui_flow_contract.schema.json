{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ui_flow_contract.schema.json",
  "title": "UI Flow Contract",
  "type": "object",
  "required": ["schema_version", "ui_framework", "screens", "data_bindings", "playmode_checks"],
  "properties": {
    "schema_version": {"type": "string"},
    "ui_framework": {"type": "string", "minLength": 1},
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["screen_id", "panels", "controls", "visible_on_start", "acceptance_tests"],
        "properties": {
          "screen_id": {"type": "string"},
          "scene_context": {"type": "string"},
          "required": {"type": "boolean"},
          "panels": {"type": "array", "items": {"type": "string"}},
          "controls": {"type": "array", "items": {"type": "object"}},
          "visible_on_start": {"type": "boolean"},
          "open_close_rules": {"type": "string"},
          "acceptance_tests": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "data_bindings": {"type": "array"},
    "playmode_checks": {"type": "array", "minItems": 1},
    "screen_graph": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "trigger"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "trigger": {"type": "string"}
        }
      }
    },
    "hud": {
      "type": "object",
      "properties": {
        "screen_id": {"type": "string"},
        "widgets": {"type": "array", "items": {"type": "string"}}
      }
    },
    "input_entry_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["control_id", "action_binding"],
        "properties": {
          "control_id": {"type": "string"},
          "action_binding": {"type": "string"},
          "screen_id": {"type": "string"}
        }
      }
    },
    "empty_states": {"type": "array", "items": {"type": "object"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "contract_refs": {"type": "object"}
  }
}
