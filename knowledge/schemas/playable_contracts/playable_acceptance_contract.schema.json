{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "playable_acceptance_contract.schema.json",
  "title": "Playable Acceptance Contract",
  "type": "object",
  "required": [
    "schema_version",
    "editmode_checks",
    "playmode_checks",
    "visual_checks",
    "interaction_checks",
    "data_progression_checks",
    "build_checks"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "playmode_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "start_scene",
          "steps",
          "expected_visible_text_or_object",
          "expected_state_change",
          "timeout_seconds",
          "blocking"
        ]
      }
    }
  }
}
