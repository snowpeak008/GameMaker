{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_mount_contract.schema.json",
  "title": "Asset Mount Contract",
  "type": "object",
  "required": ["schema_version", "assets"],
  "properties": {
    "schema_version": {"type": "string"},
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "asset_type",
          "target_path",
          "required",
          "consumer_system",
          "mount_point",
          "fallback_strategy",
          "acceptance_check"
        ],
        "properties": {
          "asset_id": {"type": "string"},
          "asset_type": {"type": "string"},
          "target_path": {"type": "string"},
          "unity_target_path": {"type": "string"},
          "required": {"type": "boolean"},
          "consumer_system": {"type": "string"},
          "mount_point": {"type": "string"},
          "fallback_strategy": {"type": "string"},
          "acceptance_check": {"type": "string"},
          "usage_context": {"type": "string"},
          "required_format": {"type": "string"},
          "required_size": {"type": "object"},
          "transparency": {"type": "string"},
          "viewpoint": {"type": "string"},
          "import_settings": {"type": "object"},
          "linked_contract_field": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "contract_refs": {"type": "object"}
  }
}
