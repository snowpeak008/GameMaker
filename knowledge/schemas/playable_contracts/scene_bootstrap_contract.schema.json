{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene_bootstrap_contract.schema.json",
  "title": "Scene Bootstrap Contract",
  "type": "object",
  "required": [
    "schema_version",
    "engine",
    "start_scene",
    "build_settings_policy",
    "camera",
    "runtime_roots",
    "initial_objects",
    "ui_roots",
    "data_loaders",
    "input_roots",
    "fallback_visuals",
    "scene_acceptance"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "engine": {"type": "string", "minLength": 1},
    "start_scene": {"type": "string", "minLength": 1},
    "build_settings_policy": {
      "type": "object",
      "properties": {
        "make_start_scene_first": {"type": "boolean"}
      }
    },
    "camera": {
      "type": "object",
      "required": ["role", "projection", "required"],
      "properties": {
        "role": {"type": "string"},
        "projection": {"type": "string"},
        "position": {"type": "array", "items": {"type": "number"}},
        "rotation": {"type": "array", "items": {"type": "number"}},
        "orthographic_size": {"type": "number"},
        "field_of_view": {"type": "number"},
        "clear_flags": {"type": "string"},
        "background_color": {"type": "string"},
        "required": {"type": "boolean"}
      }
    },
    "runtime_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "required_components": {"type": "array", "items": {"type": "string"}},
          "required": {"type": "boolean"}
        }
      }
    },
    "initial_objects": {"type": "array", "items": {"type": "object"}},
    "ui_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "screen"],
        "properties": {
          "name": {"type": "string"},
          "screen": {"type": "string"},
          "canvas_mode": {"type": "string"},
          "required": {"type": "boolean"}
        }
      }
    },
    "data_loaders": {"type": "array", "items": {"type": "object"}},
    "input_roots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "actions"],
        "properties": {
          "name": {"type": "string"},
          "actions": {"type": "array", "items": {"type": "string"}},
          "required": {"type": "boolean"}
        }
      }
    },
    "event_system": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "required": {"type": "boolean"}
      }
    },
    "objective_tracker": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "state_model": {"type": "string"},
        "required": {"type": "boolean"}
      }
    },
    "fallback_visuals": {"type": "array", "items": {"type": "object"}},
    "scene_acceptance": {"type": "array", "minItems": 1},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "contract_refs": {"type": "object"}
  }
}
