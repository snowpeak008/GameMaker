{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core_playable_contract.schema.json",
  "title": "Core Playable Contract",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "project_type",
    "player_model",
    "core_loop",
    "action_verbs",
    "state_model",
    "runtime_systems",
    "demo_flow_id",
    "required_contracts"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "project_id": {"type": "string", "minLength": 1},
    "project_type": {"type": "string", "minLength": 1},
    "player_model": {"type": "object"},
    "core_loop": {
      "type": "object",
      "required": [
        "loop_id",
        "start_state",
        "player_action",
        "state_change",
        "feedback",
        "reward_or_progress",
        "repeat_condition",
        "completion_condition"
      ]
    },
    "action_verbs": {"type": "array", "minItems": 1},
    "state_model": {"type": "array", "minItems": 1},
    "runtime_systems": {"type": "array", "minItems": 1},
    "demo_flow_id": {"type": "string", "minLength": 1},
    "required_contracts": {"type": "array", "minItems": 1}
  }
}
