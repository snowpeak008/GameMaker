{
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "consumer_stage",
    "source_contract_protocol",
    "source_design_handoff",
    "source_design_markdown",
    "source_coverage",
    "derivation_policy",
    "visual_language",
    "assets",
    "visual_states",
    "ux_signal_bindings",
    "drift_checks",
    "path_bindings",
    "source_files",
    "quality"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "consumer_stage": {"type": "string", "enum": ["step_4_art_requirements"]},
    "source_contract_protocol": {"type": "string"},
    "source_design_handoff": {"type": "string"},
    "source_design_markdown": {"type": "string"},
    "source_coverage": {
      "type": "object",
      "required": ["consumer_view", "consumer_view_present", "visual_objects", "ux_signals", "knowledge_units", "knowledge_relations", "coverage_gaps"],
      "properties": {
        "design_handoff_schema_version": {"type": "string"},
        "consumer_view": {"type": "string"},
        "consumer_view_present": {"type": "boolean"},
        "systems": {"type": "integer"},
        "resources": {"type": "integer"},
        "visual_objects": {"type": "integer"},
        "ux_signals": {"type": "integer"},
        "knowledge_units": {"type": "integer"},
        "knowledge_relations": {"type": "integer"},
        "authority_domains": {"type": "integer"},
        "executable_scenarios": {"type": "integer"},
        "coverage_gaps": {"type": "array", "items": {"type": "string"}}
      }
    },
    "derivation_policy": {
      "type": "object",
      "required": ["may_derive", "must_not_invent", "markdown_role"],
      "properties": {
        "may_derive": {"type": "array", "items": {"type": "string"}},
        "must_not_invent": {"type": "array", "items": {"type": "string"}},
        "markdown_role": {"type": "string"}
      }
    },
    "visual_language": {
      "type": "object",
      "required": ["style_tokens", "material_tokens", "lighting_tokens"],
      "properties": {
        "style_tokens": {"type": "array", "items": {"type": "string"}},
        "material_tokens": {"type": "array", "items": {"type": "string"}},
        "lighting_tokens": {"type": "array", "items": {"type": "string"}}
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "name",
          "category",
          "source_visual_object_id",
          "source_system_ids",
          "purpose",
          "required_readability",
          "production_specs",
          "forbidden_visuals",
          "acceptance_checks"
        ],
        "properties": {
          "asset_id": {"type": "string"},
          "name": {"type": "string"},
          "category": {"type": "string", "enum": ["illustration", "ui", "vfx"]},
          "source_visual_object_id": {"type": "string"},
          "source_system_ids": {"type": "array", "items": {"type": "string"}},
          "purpose": {"type": "string"},
          "required_readability": {"type": "array", "items": {"type": "string"}},
          "production_specs": {"type": "object"},
          "forbidden_visuals": {"type": "array", "items": {"type": "string"}},
          "acceptance_checks": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "visual_states": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["visual_state_id", "asset_id", "source_state_id", "state_name", "required_difference"],
        "properties": {
          "visual_state_id": {"type": "string"},
          "asset_id": {"type": "string"},
          "source_state_id": {"type": "string"},
          "state_name": {"type": "string"},
          "required_difference": {"type": "string"}
        }
      }
    },
    "ux_signal_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "ux_signal_id", "asset_id", "required_feedback", "timing"],
        "properties": {
          "binding_id": {"type": "string"},
          "ux_signal_id": {"type": "string"},
          "asset_id": {"type": "string"},
          "required_feedback": {"type": "string"},
          "timing": {"type": "string"}
        }
      }
    },
    "drift_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "asset_id", "rule", "severity"],
        "properties": {
          "check_id": {"type": "string"},
          "asset_id": {"type": "string"},
          "rule": {"type": "string"},
          "severity": {"type": "string", "enum": ["OK", "WARNING", "BLOCK", "UNKNOWN"]}
        }
      }
    },
    "path_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "asset_id", "source_path", "target_path", "output_files"],
        "properties": {
          "binding_id": {"type": "string"},
          "asset_id": {"type": "string"},
          "source_path": {"type": "string"},
          "target_path": {"type": "string"},
          "output_files": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "source_files": {"type": "object"},
    "quality": {
      "type": "object",
      "required": ["schema", "valid", "blockers", "warnings"],
      "properties": {
        "schema": {"type": "string"},
        "valid": {"type": "boolean"},
        "blockers": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
