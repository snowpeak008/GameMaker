{
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "consumer_stage",
    "source_contract_protocol",
    "source_design_handoff",
    "source_design_markdown",
    "source_coverage",
    "derivation_policy",
    "systems",
    "contracts",
    "entities",
    "events",
    "authority",
    "acceptance",
    "design_fact_bindings",
    "path_bindings",
    "source_files",
    "quality"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "consumer_stage": {"type": "string", "enum": ["step_3_program_requirements"]},
    "source_contract_protocol": {"type": "string"},
    "source_design_handoff": {"type": "string"},
    "source_design_markdown": {"type": "string"},
    "source_coverage": {
      "type": "object",
      "required": ["consumer_view", "consumer_view_present", "knowledge_units", "knowledge_relations", "authority_domains", "executable_scenarios", "coverage_gaps"],
      "properties": {
        "design_handoff_schema_version": {"type": "string"},
        "consumer_view": {"type": "string"},
        "consumer_view_present": {"type": "boolean"},
        "systems": {"type": "integer"},
        "resources": {"type": "integer"},
        "visual_objects": {"type": "integer"},
        "ux_signals": {"type": "integer"},
        "knowledge_units": {"type": "integer"},
        "knowledge_relations": {"type": "integer"},
        "authority_domains": {"type": "integer"},
        "executable_scenarios": {"type": "integer"},
        "coverage_gaps": {"type": "array", "items": {"type": "string"}}
      }
    },
    "derivation_policy": {
      "type": "object",
      "required": ["may_derive", "must_not_invent", "markdown_role"],
      "properties": {
        "may_derive": {"type": "array", "items": {"type": "string"}},
        "must_not_invent": {"type": "array", "items": {"type": "string"}},
        "markdown_role": {"type": "string"}
      }
    },
    "systems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["system_id", "source_design_system_id", "name", "responsibility", "description"],
        "properties": {
          "system_id": {"type": "string"},
          "source_design_system_id": {"type": "string"},
          "name": {"type": "string"},
          "responsibility": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contract_id", "source_system", "target_system", "method", "inputs", "outputs", "errors"],
        "properties": {
          "contract_id": {"type": "string"},
          "source_system": {"type": "string"},
          "target_system": {"type": "string"},
          "method": {"type": "string", "enum": ["query", "command", "event"]},
          "inputs": {"type": "array", "items": {"type": "string"}},
          "outputs": {"type": "array", "items": {"type": "string"}},
          "errors": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id", "entity_name", "owner_system", "source_text"],
        "properties": {
          "entity_id": {"type": "string"},
          "entity_name": {"type": "string"},
          "owner_system": {"type": "string"},
          "source_text": {"type": "string"}
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "event", "source_text"],
        "properties": {
          "event_id": {"type": "string"},
          "event": {"type": "string"},
          "source_text": {"type": "string"}
        }
      }
    },
    "authority": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["authority_id", "authority", "source_text"],
        "properties": {
          "authority_id": {"type": "string"},
          "authority": {"type": "string"},
          "source_text": {"type": "string"}
        }
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["acceptance_id", "acceptance", "source_text"],
        "properties": {
          "acceptance_id": {"type": "string"},
          "acceptance": {"type": "string"},
          "source_text": {"type": "string"}
        }
      }
    },
    "design_fact_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "target_requirement_id", "source_fact_ids", "derivation"],
        "properties": {
          "binding_id": {"type": "string"},
          "target_requirement_id": {"type": "string"},
          "source_fact_ids": {"type": "array", "items": {"type": "string"}},
          "derivation": {"type": "string"}
        }
      }
    },
    "path_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "owner_id", "target_path", "allowed_outputs", "source"],
        "properties": {
          "binding_id": {"type": "string"},
          "owner_id": {"type": "string"},
          "target_path": {"type": "string"},
          "allowed_outputs": {"type": "array", "items": {"type": "string"}},
          "source": {"type": "string"}
        }
      }
    },
    "source_files": {"type": "object"},
    "quality": {
      "type": "object",
      "required": ["schema", "valid", "blockers", "warnings"],
      "properties": {
        "schema": {"type": "string"},
        "valid": {"type": "boolean"},
        "blockers": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
