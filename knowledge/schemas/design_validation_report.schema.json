{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutoDesignMaker Design Validation Report",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "valid",
    "validation_errors",
    "validation_warnings",
    "conflicts",
    "coverage"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "stage_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "blocked"
      ]
    },
    "valid": {
      "type": "boolean"
    },
    "validation_errors": {
      "type": "array"
    },
    "validation_warnings": {
      "type": "array"
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "coverage": {
      "type": "object",
      "required": [
        "domains",
        "nodes",
        "checklist",
        "optionGroups",
        "coverageRatio"
      ],
      "properties": {
        "domains": {
          "type": "integer",
          "minimum": 0
        },
        "nodes": {
          "type": "integer",
          "minimum": 0
        },
        "checklist": {
          "type": "integer",
          "minimum": 0
        },
        "optionGroups": {
          "type": "integer",
          "minimum": 0
        },
        "options": {
          "type": "integer",
          "minimum": 0
        },
        "domainsWithChecklist": {
          "type": "integer",
          "minimum": 0
        },
        "coverageRatio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "data_source": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
