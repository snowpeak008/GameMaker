{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene_assembly_task_requirements.schema.json",
  "title": "Scene Assembly Task Requirements",
  "type": "object",
  "required": ["schema_version", "tasks"],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "target_object", "required_components", "source_refs"],
        "properties": {
          "task_id": {"type": "string"},
          "target_object": {"type": "string"},
          "required_components": {"type": "array", "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
