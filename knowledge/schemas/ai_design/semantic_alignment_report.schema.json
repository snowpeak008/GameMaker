{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "semantic_alignment_report.schema.json",
  "title": "Semantic Alignment Report",
  "type": "object",
  "required": ["schema_version", "status", "alignment_checks"],
  "properties": {
    "schema_version": {"type": "string"},
    "status": {"type": "string"},
    "project_signature": {"type": "string"},
    "source_contracts": {"type": "array", "items": {"type": "string"}},
    "alignment_checks": {"type": "array", "items": {"type": "object"}},
    "coverage_summary": {"type": "object"},
    "blockers": {"type": "array", "items": {"type": "object"}},
    "warnings": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": true
}
