{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_requirements_resolved.schema.json",
  "title": "Asset Requirements Resolved",
  "type": "object",
  "required": ["schema_version", "source_refs", "resolved_assets", "unresolved_assets"],
  "properties": {
    "schema_version": {"type": ["string", "integer"]},
    "generated_at": {"type": "string"},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "resolved_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "asset_type",
          "source_contract_refs",
          "unity_target_path",
          "consumer_system",
          "mount_point",
          "fallback_policy"
        ],
        "properties": {
          "asset_id": {"type": "string"},
          "asset_type": {"type": "string"},
          "source_contract_refs": {"type": "array", "items": {"type": "string"}},
          "unity_target_path": {"type": "string"},
          "consumer_system": {"type": "string"},
          "mount_point": {"type": "string"},
          "fallback_policy": {"type": "string"},
          "acceptance_check": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "unresolved_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "reason", "severity"],
        "properties": {
          "asset_id": {"type": "string"},
          "reason": {"type": "string"},
          "severity": {"type": "string", "enum": ["warning", "blocking"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
