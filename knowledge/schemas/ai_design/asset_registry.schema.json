{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_registry.schema.json",
  "title": "Asset Registry",
  "type": "object",
  "required": ["schema_version", "generated_at", "assets"],
  "properties": {
    "schema_version": {"type": ["string", "integer"]},
    "generated_at": {"type": "string"},
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "name",
          "asset_type",
          "source",
          "source_refs",
          "purpose",
          "target_path",
          "consumer_system",
          "mount_point",
          "fallback_strategy",
          "acceptance_check"
        ],
        "properties": {
          "asset_id": {"type": "string"},
          "name": {"type": "string"},
          "asset_type": {"type": "string"},
          "source": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "string"}},
          "purpose": {"type": "string"},
          "target_path": {"type": "string"},
          "unity_target_path": {"type": "string"},
          "consumer_system": {"type": "string"},
          "mount_point": {"type": "string"},
          "fallback_strategy": {"type": "string"},
          "acceptance_check": {"type": "string"},
          "priority": {"type": "string"},
          "complexity": {"type": "string"},
          "required_for_phase": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
