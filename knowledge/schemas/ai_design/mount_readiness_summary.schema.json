{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mount_readiness_summary.schema.json",
  "title": "Mount Readiness Summary",
  "type": "object",
  "required": ["schema_version", "generated_at", "ready", "mount_items"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "ready": {
      "type": "boolean"
    },
    "mount_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_path", "asset_id", "fallback_policy", "source_refs"],
        "properties": {
          "target_path": {
            "type": "string"
          },
          "asset_id": {
            "type": "string"
          },
          "fallback_policy": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
