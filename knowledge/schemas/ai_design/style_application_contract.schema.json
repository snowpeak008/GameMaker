{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Style Application Contract",
  "type": "object",
  "required": ["schema_version", "source_refs", "style_constraints"],
  "properties": {
    "schema_version": {"type": "string"},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "style_constraints": {
      "type": "object",
      "properties": {
        "tile": {"type": "object"},
        "icon": {"type": "object"},
        "ui": {"type": "object"},
        "background": {"type": "object"},
        "effect": {"type": "object"}
      }
    },
    "blockers": {"type": "array"},
    "warnings": {"type": "array"}
  }
}
