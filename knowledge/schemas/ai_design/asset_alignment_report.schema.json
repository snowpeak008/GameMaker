{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_alignment_report.schema.json",
  "title": "Asset Alignment Report",
  "type": "object",
  "required": ["schema_version", "generated_at", "alignment_items", "gaps"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "alignment_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["program_task_id", "asset_id", "status", "source_refs"],
        "properties": {
          "program_task_id": {
            "type": "string"
          },
          "asset_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap_id", "severity", "message"],
        "properties": {
          "gap_id": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
