{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ui_runtime_task_requirements.schema.json",
  "title": "UI Runtime Task Requirements",
  "type": "object",
  "required": ["schema_version", "screens", "tasks"],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["screen_id"],
        "properties": {
          "screen_id": {"type": "string"},
          "required_widgets": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "ui_target", "binding_refs"],
        "properties": {
          "task_id": {"type": "string"},
          "ui_target": {"type": "string"},
          "binding_refs": {"type": "array", "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
