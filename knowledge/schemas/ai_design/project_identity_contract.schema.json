{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_identity_contract.schema.json",
  "title": "Project Identity Contract",
  "type": "object",
  "required": ["schema_version", "draft_session_id", "project_signature"],
  "properties": {
    "schema_version": {"type": "string"},
    "draft_session_id": {"type": "string"},
    "project_signature": {"type": "string"},
    "project_name": {"type": "string"},
    "source_artifacts": {"type": "array", "items": {"type": "string"}},
    "identity_terms": {"type": "array", "items": {"type": "string"}},
    "excluded_template_terms": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": true
}
