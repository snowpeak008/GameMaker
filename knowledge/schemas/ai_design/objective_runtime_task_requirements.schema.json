{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "objective_runtime_task_requirements.schema.json",
  "title": "Objective Runtime Task Requirements",
  "type": "object",
  "required": ["schema_version", "objectives", "tasks"],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["objective_id", "success_condition", "source_refs"],
        "properties": {
          "objective_id": {"type": "string"},
          "success_condition": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "objective_id", "runtime_target"],
        "properties": {
          "task_id": {"type": "string"},
          "objective_id": {"type": "string"},
          "runtime_target": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
