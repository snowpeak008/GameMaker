{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audio_placeholder_plan.schema.json",
  "title": "Audio Placeholder Plan",
  "type": "object",
  "required": ["schema_version", "placeholder_files", "replacement_requirements", "source_refs"],
  "properties": {
    "schema_version": {"type": ["string", "integer"]},
    "generated_at": {"type": "string"},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "placeholder_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "placeholder_id",
          "path",
          "consumer_system",
          "replace_later",
          "acceptance_check"
        ],
        "properties": {
          "placeholder_id": {"type": "string"},
          "path": {"type": "string"},
          "consumer_system": {"type": "string"},
          "replace_later": {"type": "boolean"},
          "acceptance_check": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "replacement_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["placeholder_id", "audio_role", "future_provider_requirement"],
        "properties": {
          "placeholder_id": {"type": "string"},
          "audio_role": {"type": "string"},
          "future_provider_requirement": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
