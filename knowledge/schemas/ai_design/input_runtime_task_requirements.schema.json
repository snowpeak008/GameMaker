{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "input_runtime_task_requirements.schema.json",
  "title": "Input Runtime Task Requirements",
  "type": "object",
  "required": ["schema_version", "actions", "tasks"],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "binding", "source_refs"],
        "properties": {
          "action_id": {"type": "string"},
          "binding": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "action_id", "runtime_target"],
        "properties": {
          "task_id": {"type": "string"},
          "action_id": {"type": "string"},
          "runtime_target": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
