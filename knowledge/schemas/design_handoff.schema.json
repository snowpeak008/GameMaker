{
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_sections",
    "design_kernel",
    "term_refs",
    "systems",
    "resources",
    "visual_objects",
    "ux_signals",
    "risks",
    "knowledge_units",
    "knowledge_relations",
    "authority_domains",
    "executable_scenarios",
    "validation_profiles",
    "consumer_views",
    "quality",
    "governance_decision_ids"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "source_direction_ids": {"type": "array", "items": {"type": "string"}},
    "source_sections": {"type": "object"},
    "design_kernel": {
      "type": "object",
      "required": ["core_promise", "primary_loop", "main_pressure", "main_reward", "progression_axis", "failure_state"],
      "properties": {
        "core_promise": {"type": "string"},
        "primary_loop": {"type": "array", "items": {"type": "string"}},
        "main_pressure": {"type": "string"},
        "main_reward": {"type": "string"},
        "progression_axis": {"type": "string"},
        "irreversible_costs": {"type": "array", "items": {"type": "string"}},
        "failure_state": {"type": "string"},
        "world_or_context_constraint": {"type": "string"}
      }
    },
    "invariants": {"type": "array", "items": {"type": "object"}},
    "term_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "type": {"type": "string"}
        }
      }
    },
    "systems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["system_id", "name", "owner", "player_promise"],
        "properties": {
          "system_id": {"type": "string"},
          "name": {"type": "string"},
          "owner": {"type": "string"},
          "player_promise": {"type": "string"},
          "owned_facts": {"type": "array", "items": {"type": "string"}},
          "referenced_facts": {"type": "array", "items": {"type": "string"}},
          "entry_rules": {"type": "array", "items": {"type": "string"}},
          "exit_rules": {"type": "array", "items": {"type": "string"}},
          "player_actions": {"type": "array", "items": {"type": "string"}},
          "feedback": {"type": "array", "items": {"type": "string"}},
          "states": {"type": "array", "items": {"type": "object"}},
          "resources": {"type": "array", "items": {"type": "string"}},
          "dependencies": {"type": "array", "items": {"type": "object"}},
          "ux_requirements": {"type": "array", "items": {"type": "string"}},
          "technical_requirements": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "resources": {"type": "array", "items": {"type": "object"}},
    "visual_objects": {"type": "array", "items": {"type": "object"}},
    "ux_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ux_signal_id", "source_unit", "player_decision_supported", "required_feedback"],
        "properties": {
          "ux_signal_id": {"type": "string"},
          "source_unit": {"type": "string"},
          "source_relation": {"type": "string"},
          "player_decision_supported": {"type": "string"},
          "timing": {"type": "string"},
          "required_feedback": {"type": "string"},
          "failure_if_missing": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "object"}}
        }
      }
    },
    "risks": {"type": "array", "items": {"type": "object"}},
    "knowledge_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "domain", "status", "summary"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "domain": {"type": "string"},
          "name": {"type": "string"},
          "status": {"type": "string"},
          "summary": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "object"}},
          "consumed_by": {"type": "array", "items": {"type": "string"}},
          "validation_profile": {"type": "string"},
          "version": {"type": "object"}
        }
      }
    },
    "knowledge_relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "type"],
        "properties": {
          "id": {"type": "string"},
          "from": {"type": "string"},
          "to": {"type": "string"},
          "type": {"type": "string"},
          "condition": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "object"}},
          "validation": {"type": "string"}
        }
      }
    },
    "authority_domains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "target", "owner", "write_policy"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "target": {"type": "string"},
          "owner": {"type": "string"},
          "write_policy": {"type": "string"},
          "requesters": {"type": "array", "items": {"type": "string"}},
          "readers": {"type": "array", "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "object"}}
        }
      }
    },
    "executable_scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "given": {"type": "array", "items": {"type": "string"}},
          "when": {"type": "array", "items": {"type": "string"}},
          "then": {"type": "array", "items": {"type": "string"}},
          "covered_units": {"type": "array", "items": {"type": "string"}},
          "covered_relations": {"type": "array", "items": {"type": "string"}},
          "expected_events": {"type": "array", "items": {"type": "string"}},
          "expected_state_changes": {"type": "array", "items": {"type": "string"}},
          "negative": {"type": "boolean"}
        }
      }
    },
    "validation_profiles": {"type": "array", "items": {"type": "object"}},
    "consumer_views": {"type": "object"},
    "quality": {"type": "object"},
    "governance_decision_ids": {"type": "array", "items": {"type": "string"}}
  }
}
